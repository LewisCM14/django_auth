# Runtime mode: dev (local) or iis (production)
AUTH_MODE=dev

# Django core settings
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Placeholder replaced by the tagged-release
API_VERSION=APP_VERSION
SECURE_SSL_REDIRECT=False
AUTHZ_HIDE_FORBIDDEN_AS_NOT_FOUND=False

# Dev mode identity/role (DEV_USER_ROLE must match api.constants.ROLES)
DEV_USER_IDENTITY=dev_admin
DEV_USER_ROLE=app_admin

# AD group DNs mapped to application roles (required in all modes)
ADMIN_AD_GROUP=CN=app-admins,OU=Groups,DC=corp,DC=local
VIEWER_AD_GROUP=CN=app-viewers,OU=Groups,DC=corp,DC=local

# LDAP / AD settings (used in AUTH_MODE=iis)
LDAP_SERVER_URI=ldap://dc.corp.local
LDAP_BASE_DN=DC=corp,DC=local

# CORS (optional for cross-origin frontend)
CORS_ALLOWED_ORIGINS=

# Logging
LOG_FORMAT=text       # text (dev) or json (production)
LOG_LEVEL=DEBUG       # Python log level (DEBUG, INFO, WARNING, ERROR)

# Optional Oracle adapter settings (required only when Oracle-backed services are used)
# ORACLE_USERNAME=app_readonly
# ORACLE_PASSWORD=replace-with-secret-manager-value
# ORACLE_DSN=tcps://db.corp.local:2484/APPDB
# ORACLE_REQUIRE_TLS=true
