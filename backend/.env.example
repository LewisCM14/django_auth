# Runtime mode: dev (local) or iis (production)
AUTH_MODE=dev

# Django core settings
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Dev mode identity/role
DEV_USER_IDENTITY=dev_admin
DEV_USER_ROLE=admin

# LDAP / AD settings (used in AUTH_MODE=iis)
LDAP_SERVER_URI=ldap://dc.corp.local
LDAP_BASE_DN=DC=corp,DC=local

# CORS (optional for cross-origin frontend)
CORS_ALLOWED_ORIGINS=

# Logging
LOG_FORMAT=text       # text (dev) or json (production)
LOG_LEVEL=DEBUG       # Python log level (DEBUG, INFO, WARNING, ERROR)
